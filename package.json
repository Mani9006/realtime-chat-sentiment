{
  "name": "chat-sentiment-app",
  "version": "1.0.0",
  "description": "Real-time Chat Application with Sentiment Analysis - Node.js, Express, Socket.IO",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --coverage --verbose",
    "test:watch": "jest --watch",
    "lint": "eslint src/ public/js/ tests/",
    "lint:fix": "eslint src/ public/js/ tests/ --fix"
  },
  "keywords": [
    "chat",
    "real-time",
    "socket-io",
    "sentiment-analysis",
    "express",
    "node.js"
  ],
  "author": "Mani <myfamily9006@gmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "dompurify": "^3.0.6",
    "express": "^4.22.1",
    "jsdom": "^23.0.1",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "testMatch": [
      "**/tests/**/*.js"
    ]
  }
}
